<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-root .runsettings picked up automatically by the MikeSchulze/gdunit4-action,
  which only scans the working directory for a project-specific runsettings and
  otherwise falls back to its bundled default (20 s compile timeout). Mirrors the
  values in AshesofVelsingrad/integration_tests/.runsettings but with the GodotBin
  hardcoded path stripped so it resolves from $GODOT_BIN on Linux runners.
-->
<RunSettings>
  <GdUnit4>
    <Parameters>
      <Parameter name="godot-parameters" value="--headless --no-import" />
      <Parameter name="CompileProcessTimeout" value="120000" />
    </Parameters>
  </GdUnit4>
</RunSettings>
