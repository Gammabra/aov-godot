{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "scripts/**/*.cs",
            "scripts/*.cs"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/.godot/**"
          ]
        }
      ],
      "dest": "api",
      "allowCompilationErrors": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        "TargetFramework": "net9.0"
      },
      "filter": "filterConfig.yml",
      "globalNamespaceId": "Global"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/**.md",
          "docs/**/*.md",
          "toc.yml",
          "**.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false,
    "globalMetadata": {
      "_appTitle": "Ashes of Velsingrad Documentation",
      "_appName": "Ashes of Velsingrad",
      "_appFooter": "© 2025 Gammabra Studios. All Rights Reserved.",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/Gammabra/aov-godot",
        "branch": "develop"
      },
      "_gitUrlPattern": "github",
      "_appLogoPath": "images/aov-logo-transparent.png",
      "_enableNewTab": true
    }
  }
}
