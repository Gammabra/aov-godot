<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Include>[AshesofVelsingrad]*</Include>
          <UseSourceLink>false</UseSourceLink>
          <IncludeTestAssembly>true</IncludeTestAssembly>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>

  <GdUnit4>
    <Parameters>
      <Parameter name="godot-parameters" value="--headless --no-build --no-import" />
      <Parameter name="CompileProcessTimeout" value="120000" />
    </Parameters>
  </GdUnit4>
</RunSettings>